{
  "_id": "view-admin-users",
  "_type": "view",
  "class": "acp-page",
  "_children": [
    {
      "_type": "label",
      "class": "acp-title",
      "_text": "Admin Users"
    },
    {
      "_type": "view",
      "class": "acp-table-scroll",
      "_children": [
        {
          "_type": "table",
          "_id": "admin-users-table",
          "_data_source": "acp.ui.admin_users.table_rows",
          "_columns": [
            {
              "key": "id",
              "label": "User ID",
              "width": "180px"
            },
            {
              "key": "name",
              "label": "Name",
              "width": "180px"
            },
            {
              "key": "username",
              "label": "Username",
              "width": "220px"
            },
            {
              "key": "role",
              "label": "Role",
              "width": "100px"
            }
          ],
          "_dense": true,
          "_striped": true,
          "_bordered": true,
          "_hover": false,
          "_empty_text": "No admin users"
        }
      ]
    },
    {
      "_type": "label",
      "class": "acp-form-title",
      "_text": "Add Admin"
    },
    {
      "_type": "input",
      "_id": "admin-create-name-input",
      "class": "acp-input",
      "placeholder": "Name"
    },
    {
      "_type": "input",
      "_id": "admin-create-username-input",
      "class": "acp-input",
      "placeholder": "Username or email"
    },
    {
      "_type": "input",
      "_id": "admin-create-password-input",
      "class": "acp-input",
      "_input_type": "password",
      "placeholder": "Password"
    },
    {
      "_type": "button",
      "_id": "admin-create-btn",
      "class": "acp-primary-btn",
      "_text": "Add Admin",
      "_on_click": {
        "_op": "acp-ui-action",
        "_params": {
          "_action": "admin_create"
        }
      }
    },
    {
      "_type": "label",
      "class": "acp-form-title",
      "_text": "Update/Delete Admin"
    },
    {
      "_type": "input",
      "_id": "admin-edit-id-input",
      "class": "acp-input",
      "placeholder": "Admin id"
    },
    {
      "_type": "input",
      "_id": "admin-edit-name-input",
      "class": "acp-input",
      "placeholder": "New name (optional)"
    },
    {
      "_type": "input",
      "_id": "admin-edit-username-input",
      "class": "acp-input",
      "placeholder": "New username/email (optional)"
    },
    {
      "_type": "input",
      "_id": "admin-edit-password-input",
      "class": "acp-input",
      "_input_type": "password",
      "placeholder": "New password (optional)"
    },
    {
      "_type": "view",
      "class": "acp-inline-actions",
      "_children": [
        {
          "_type": "button",
          "_id": "admin-update-btn",
          "class": "acp-secondary-btn",
          "_text": "Update",
          "_on_click": {
            "_op": "acp-ui-action",
            "_params": {
              "_action": "admin_update"
            }
          }
        },
        {
          "_type": "button",
          "_id": "admin-delete-btn",
          "class": "acp-danger-btn",
          "_text": "Delete",
          "_on_click": {
            "_op": "acp-ui-action",
            "_params": {
              "_action": "admin_delete"
            }
          }
        }
      ]
    }
  ]
}
