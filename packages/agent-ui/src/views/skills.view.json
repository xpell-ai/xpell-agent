{
  "_id": "view-skills",
  "_type": "view",
  "class": "acp-page",
  "_children": [
    {
      "_type": "label",
      "class": "acp-title",
      "_text": "Skills"
    },
    {
      "_type": "view",
      "class": "acp-table-scroll",
      "_children": [
        {
          "_type": "table",
          "_id": "skills-table",
          "_data_source": "acp.ui.skills.table_rows",
          "_columns": [
            {
              "key": "id",
              "label": "Skill ID",
              "width": "240px"
            },
            {
              "key": "version",
              "label": "Version",
              "width": "100px"
            },
            {
              "key": "enabled",
              "label": "Enabled",
              "width": "100px"
            },
            {
              "key": "status",
              "label": "Status",
              "width": "120px"
            },
            {
              "key": "error",
              "label": "Error",
              "width": "260px"
            },
            {
              "key": "action",
              "label": "Action",
              "width": "120px"
            }
          ],
          "_dense": true,
          "_striped": true,
          "_bordered": true,
          "_hover": false,
          "_empty_text": "No skills"
        }
      ]
    },
    {
      "_type": "input",
      "_id": "skills-skill-id-input",
      "class": "acp-input",
      "placeholder": "Skill id (example: telegram)"
    },
    {
      "_type": "view",
      "class": "acp-inline-actions",
      "_children": [
        {
          "_type": "button",
          "_id": "skills-enable-btn",
          "class": "acp-secondary-btn",
          "_text": "Enable",
          "_on_click": {
            "_op": "acp-ui-action",
            "_params": {
              "_action": "skills_enable"
            }
          }
        },
        {
          "_type": "button",
          "_id": "skills-disable-btn",
          "class": "acp-danger-btn",
          "_text": "Disable",
          "_on_click": {
            "_op": "acp-ui-action",
            "_params": {
              "_action": "skills_disable"
            }
          }
        }
      ]
    },
    {
      "_type": "button",
      "_id": "skills-open-settings-btn",
      "class": "acp-primary-btn",
      "_text": "Open Settings",
      "_on_click": {
        "_op": "acp-ui-action",
        "_params": {
          "_action": "skills_open_settings"
        }
      }
    }
  ]
}
