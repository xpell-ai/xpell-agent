{
  "_id": "skills-config",
  "_type": "view",
  "class": "acp-page",
  "_children": [
    {
      "_type": "label",
      "class": "acp-title",
      "_text": "Skill Config"
    },
    {
      "_type": "label",
      "class": "acp-info-line",
      "_data_source": "acp.ui.skill_settings.selected_skill_text",
      "_on_data": {
        "_op": "set-text-from-data"
      }
    },
    {
      "_type": "label",
      "class": "acp-panel",
      "_data_source": "acp.ui.skill_settings.summary_text",
      "_on_data": {
        "_op": "set-text-from-data"
      }
    },
    {
      "_type": "label",
      "class": "acp-form-title",
      "_text": "Settings"
    },
    {
      "_type": "xhtml",
      "_id": "skill-config-fields-host",
      "class": "acp-panel"
    },
    {
      "_type": "label",
      "class": "acp-form-title",
      "_text": "Actions"
    },
    {
      "_type": "xhtml",
      "_id": "skill-config-actions-host",
      "class": "acp-panel"
    },
    {
      "_type": "label",
      "class": "acp-info-line",
      "_data_source": "acp.ui.skill_settings.runtime_status_text",
      "_on_data": {
        "_op": "set-text-from-data"
      }
    },
    {
      "_type": "label",
      "class": "acp-panel",
      "_data_source": "acp.ui.skill_settings.action_result_text",
      "_on_data": {
        "_op": "set-text-from-data"
      }
    },
    {
      "_type": "view",
      "class": "acp-inline-actions",
      "_children": [
        {
          "_type": "button",
          "_id": "skill-settings-save-btn",
          "class": "acp-primary-btn",
          "_text": "Save",
          "_on_click": {
            "_op": "acp-ui-action",
            "_params": {
              "_action": "skill_settings_save"
            }
          }
        },
        {
          "_type": "button",
          "_id": "skill-settings-back-btn",
          "class": "acp-secondary-btn",
          "_text": "Back",
          "_on_click": {
            "_op": "acp-ui-action",
            "_params": {
              "_action": "navigate",
              "_route": "/skills"
            }
          }
        }
      ]
    }
  ]
}
